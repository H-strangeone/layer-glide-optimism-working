model Batch {
  id               String    @id @default(uuid())
  onChainId        String?   @unique
  transactionsRoot String
  status           String    @default("pending_submission")
  submitter        String?
  submittedAt      DateTime  @default(now())
  challengeEndsAt  DateTime?
  txCount          Int       @default(0)
  onChainTxHash    String?
  transactions     PendingTransaction[]
  challenges       Challenge[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([onChainId])
}

model PendingTransaction {
  id          String   @id @default(uuid())
  fromAddress String
  toAddress   String
  valueWei    String
  nonce       Int      @default(0)
  signature   String?
  status      String   @default("pending")
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fromAddress])
  @@index([toAddress])
  @@index([batchId])
  @@index([status])
}

model Challenge {
  id                String    @id @default(uuid())
  batchId           String
  batch             Batch     @relation(fields: [batchId], references: [id])
  challengerAddress String
  fraudProofHash    String
  merkleProof       String
  status            String    @default("pending")
  rewardWei         String?
  resolvedAt        DateTime?
  onChainTxHash     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([batchId])
  @@index([status])
}

