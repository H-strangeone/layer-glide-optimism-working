generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Operator {
  id        String   @id @default(uuid())
  address   String   @unique
  isActive  Boolean  @default(true)
  bondWei   String   @default("0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractDeployment {
  id        String   @id @default(uuid())
  address   String   @unique
  network   String
  chainId   String   @default("1337")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id               String    @id @default(uuid())
  onChainId        String?   @unique
  transactionsRoot String    // TX Merkle root
  stateRoot        String?   // Post-execution state root
  prevStateRoot    String?   // Pre-execution state root (links chain)
  status           String    @default("pending_submission")
  submitter        String?
  submittedAt      DateTime  @default(now())
  challengeEndsAt  DateTime?
  txCount          Int       @default(0)
  onChainTxHash    String?
  transactions     PendingTransaction[]
  challenges       Challenge[]
  stateSnapshots   StateSnapshot[]
  withdrawalRequests WithdrawalRequest[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([onChainId])
}

model PendingTransaction {
  id          String   @id @default(uuid())
  fromAddress String
  toAddress   String
  valueWei    String
  nonce       Int      @default(0)
  signature   String?
  deadline    Int?
  status      String   @default("pending")
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fromAddress])
  @@index([toAddress])
  @@index([batchId])
  @@index([status])
}

model Challenge {
  id                String    @id @default(uuid())
  batchId           String
  batch             Batch     @relation(fields: [batchId], references: [id])
  challengerAddress String
  fraudProofHash    String
  merkleProof       String
  correctStateRoot  String?
  status            String    @default("pending")  // pending | accepted | rejected
  rewardWei         String?
  resolvedAt        DateTime?
  onChainTxHash     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([batchId])
  @@index([status])
}

// State snapshot for fraud proof reconstruction
model StateSnapshot {
  id              String   @id @default(uuid())
  batchId         String
  batch           Batch    @relation(fields: [batchId], references: [id])
  userAddress     String
  balanceWei      String
  snapshotType    String   @default("pre")  // pre | post
  createdAt       DateTime @default(now())

  @@index([batchId])
  @@index([userAddress])
}

// Withdrawal requests via Merkle proof
model WithdrawalRequest {
  id               String    @id @default(uuid())
  batchId          String?
  batch            Batch?    @relation(fields: [batchId], references: [id])
  userAddress      String
  amountWei        String
  withdrawalNonce  Int
  merkleProof      String    // JSON array
  withdrawalRoot   String
  status           String    @default("pending")  // pending | submitted | completed
  onChainTxHash    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userAddress])
  @@index([status])
}

model Balance {
  id               String   @id @default(uuid())
  address          String   @unique
  layer1BalanceWei String   @default("0")
  layer2BalanceWei String   @default("0")
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Layer2Balance {
  id              String   @id @default(uuid())
  userAddress     String
  contractAddress String
  balanceWei      String   @default("0")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userAddress, contractAddress])
  @@index([userAddress])
}

model GasAnalytics {
  id                String   @id @default(uuid())
  batchOnChainId    String
  txCount           Int
  actualGasWei      String
  estimatedL1GasWei String
  savedGasWei       String
  gasPrice          String
  blockNumber       Int
  createdAt         DateTime @default(now())
}

model Nonce {
  id              String   @id @default(uuid())
  userAddress     String
  contractAddress String
  currentNonce    Int      @default(0)

  @@unique([userAddress, contractAddress])
}
