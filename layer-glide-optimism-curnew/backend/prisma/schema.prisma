// LayerGlide Prisma Schema
// Two-layer state: balanceWei (pending) vs pendingBalanceWei (finalized — naming kept for DB compat)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Operator {
  id        String   @id @default(uuid())
  address   String   @unique
  isActive  Boolean  @default(true)
  bondWei   String   @default("0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractDeployment {
  id        String   @id @default(uuid())
  address   String   @unique
  network   String
  chainId   String   @default("1337")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id               String    @id @default(uuid())
  onChainId        String?   @unique
  // TX Merkle root (hash of all tx leaves)
  transactionsRoot String    @default("")
  // State root AFTER executing this batch
  stateRoot        String?
  // State root BEFORE executing this batch (links the chain)
  prevStateRoot    String?
  // status: pending_submission | challenge_period | finalized | rejected | failed
  status           String    @default("pending_submission")
  submitter        String?
  submittedAt      DateTime  @default(now())
  challengeEndsAt  DateTime?
  txCount          Int       @default(0)
  onChainTxHash    String?
  transactions     PendingTransaction[]
  challenges       Challenge[]
  stateSnapshots   StateSnapshot[]
  withdrawalRequests WithdrawalRequest[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([onChainId])
  @@index([stateRoot])
}

model PendingTransaction {
  id          String   @id @default(uuid())
  fromAddress String
  toAddress   String
  valueWei    String
  nonce       Int      @default(0)
  signature   String?
  deadline    Int?
  // status: pending | processing | batched | finalized | rejected | failed
  status      String   @default("pending")
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fromAddress])
  @@index([toAddress])
  @@index([batchId])
  @@index([status])
}

model Challenge {
  id                String    @id @default(uuid())
  batchId           String
  batch             Batch     @relation(fields: [batchId], references: [id])
  challengerAddress String
  fraudProofHash    String
  merkleProof       String    // JSON array
  correctStateRoot  String?
  // status: pending | accepted | rejected
  status            String    @default("pending")
  rewardWei         String?
  resolvedAt        DateTime?
  onChainTxHash     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([batchId])
  @@index([status])
}

model StateSnapshot {
  id           String   @id @default(uuid())
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  userAddress  String
  balanceWei   String
  // pre = before batch, post = after batch
  snapshotType String   @default("pre")
  createdAt    DateTime @default(now())

  @@index([batchId])
  @@index([userAddress])
}

model WithdrawalRequest {
  id              String    @id @default(uuid())
  batchId         String?
  batch           Batch?    @relation(fields: [batchId], references: [id])
  userAddress     String
  amountWei       String
  withdrawalNonce Int
  merkleProof     String    // JSON array
  withdrawalRoot  String
  // status: pending | submitted | completed
  status          String    @default("pending")
  onChainTxHash   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userAddress])
  @@index([status])
}

model Layer2Balance {
  id              String   @id @default(uuid())
  userAddress     String
  contractAddress String
  // PENDING balance: updated on every L2 tx (optimistic)
  balanceWei      String   @default("0")
  // FINALIZED balance: updated only after batch finalization
  pendingBalanceWei String  @default("0")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userAddress, contractAddress])
  @@index([userAddress])
}

model Balance {
  id               String   @id @default(uuid())
  address          String   @unique
  layer1BalanceWei String   @default("0")
  layer2BalanceWei String   @default("0")
  pendingWei       String   @default("0")
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Nonce {
  id              String @id @default(uuid())
  userAddress     String
  contractAddress String
  currentNonce    Int    @default(0)

  @@unique([userAddress, contractAddress])
}

model GasAnalytics {
  id                String   @id @default(uuid())
  batchOnChainId    String
  txCount           Int
  actualGasWei      String
  estimatedL1GasWei String
  savedGasWei       String
  gasPrice          String
  blockNumber       Int
  createdAt         DateTime @default(now())
}
